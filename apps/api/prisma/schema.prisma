generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Committee {
  id            String         @id @default(uuid())
  name          String
  year          String
  status        String         @default("active")
  createdAt     DateTime       @default(now()) @map("created_at")

  roles         Role[]
  users         User[]
  pipelines     Pipeline[]
  notifications Notification[]

  @@map("committees")
}

model Role {
  id               String      @id @default(uuid())
  committeeId      String?     @map("committee_id")
  name             String
  tier             String
  permissions      String      @default("{}") // Storing JSON as string
  responsibilities String      @default("[]") // Storing JSON as string
  sops             String      @default("[]") // Storing JSON as string
  kpis             String      @default("[]") // Storing JSON as string
  isActive         Boolean     @default(true) @map("is_active")

  committee        Committee?  @relation(fields: [committeeId], references: [id])
  users            User[]
  pipelines        Pipeline[]

  @@map("roles")
}

model User {
  id               String      @id @default(uuid())
  committeeId      String?     @map("committee_id")
  roleId           String?     @map("role_id")
  name             String
  email            String      @unique
  passwordHash     String      @map("password_hash")
  isActive         Boolean     @default(true) @map("is_active")
  lastLoginAt      DateTime?   @map("last_login_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  deletedAt        DateTime?   @map("deleted_at")

  committee        Committee?  @relation(fields: [committeeId], references: [id])
  role             Role?       @relation(fields: [roleId], references: [id])

  assignedTasks    Task[]      @relation("AssignedTo")
  createdTasks     Task[]      @relation("CreatedBy")
  comments         TaskComment[]
  taskFiles        TaskFile[]
  sentNotifications Notification[] @relation("Sender")
  receivedNotifications Notification[] @relation("Recipient")
  aiSessions       AiSession[]

  @@index([committeeId], name: "idx_users_committee")
  @@map("users")
}

model Pipeline {
  id           String      @id @default(uuid())
  committeeId  String?     @map("committee_id")
  roleId       String?     @map("role_id")
  type         String
  title        String
  description  String?
  createdAt    DateTime    @default(now()) @map("created_at")

  committee    Committee?  @relation(fields: [committeeId], references: [id])
  role         Role?       @relation(fields: [roleId], references: [id])
  tasks        Task[]

  @@index([committeeId, type], name: "idx_pipelines_type")
  @@map("pipelines")
}

model Task {
  id           String      @id @default(uuid())
  pipelineId   String?     @map("pipeline_id")
  assignedTo   String?     @map("assigned_to")
  createdBy    String?     @map("created_by")
  title        String
  description  String?
  status       String      @default("TODO")
  priority     String      @default("MEDIUM")
  deadline     DateTime?
  metadata     String      @default("{}") // JSON string
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  pipeline     Pipeline?   @relation(fields: [pipelineId], references: [id])
  assignee     User?       @relation("AssignedTo", fields: [assignedTo], references: [id])
  creator      User?       @relation("CreatedBy", fields: [createdBy], references: [id])
  comments     TaskComment[]
  files        TaskFile[]

  @@index([pipelineId], name: "idx_tasks_pipeline")
  @@index([assignedTo], name: "idx_tasks_assigned")
  @@index([status], name: "idx_tasks_status")
  @@map("tasks")
}

model TaskComment {
  id           String      @id @default(uuid())
  taskId       String?     @map("task_id")
  userId       String?     @map("user_id")
  content      String
  createdAt    DateTime    @default(now()) @map("created_at")

  task         Task?       @relation(fields: [taskId], references: [id])
  user         User?       @relation(fields: [userId], references: [id])

  @@map("task_comments")
}

model TaskFile {
  id           String      @id @default(uuid())
  taskId       String?     @map("task_id")
  attachedBy   String?     @map("attached_by")
  fileName     String?     @map("file_name")
  fileUrl      String      @map("file_url")
  mimeType     String?     @map("mime_type")
  createdAt    DateTime    @default(now()) @map("created_at")

  task         Task?       @relation(fields: [taskId], references: [id])
  user         User?       @relation(fields: [attachedBy], references: [id])

  @@map("task_files")
}

model Notification {
  id           String      @id @default(uuid())
  senderId     String?     @map("sender_id")
  recipientId  String?     @map("recipient_id")
  committeeId  String?     @map("committee_id")
  type         String
  scope        String
  message      String
  isRead       Boolean     @default(false) @map("is_read")
  sentAt       DateTime    @default(now()) @map("sent_at")

  sender       User?       @relation("Sender", fields: [senderId], references: [id])
  recipient    User?       @relation("Recipient", fields: [recipientId], references: [id])
  committee    Committee?  @relation(fields: [committeeId], references: [id])

  @@index([recipientId, isRead], name: "idx_notif_recipient")
  @@map("notifications")
}

model AiSession {
  id           String      @id @default(uuid())
  userId       String?     @map("user_id")
  agentType    String      @map("agent_type")
  messages     String      @default("[]") // JSON string
  startedAt    DateTime    @default(now()) @map("started_at")
  endedAt      DateTime?   @map("ended_at")

  user         User?       @relation(fields: [userId], references: [id])

  @@map("ai_sessions")
}
